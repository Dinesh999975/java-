package dinesh;

import java.util.Arrays;

public class ReverseArray {

	public static void main(String[] args) {
		int arr[]= {7,3,2,0,5,8};
		int first=0, last=arr.length-1;
		
		for(int i=0;i<arr.length/2;i++) {
			if(first<last) {
				int temp=arr[first];
				arr[first]=arr[last];
				arr[last]=temp;
				first++;
				last--;
			}
		}
		System.out.println(Arrays.toString(arr));

	}

}
